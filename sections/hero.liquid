{%- comment %} Composition: hero.asymmetric-block.text-card-floating-over-image
   Catalogue: ~/Desktop/design-library/compositions/hero/10-asymmetric-floating-card.md {% endcomment -%}
{%- assign img = section.settings.image | default: 'https://images.unsplash.com/photo-1626015449731-d586b6e34d2c?w=2000&q=80' -%}
<section class="hh-hero" data-section-id="{{ section.id }}">
  <div class="hh-hero__bg">
    {%- if section.settings.image != blank -%}
      {%- assign hh_alt = section.settings.heading | escape -%}
      {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'eager', alt: hh_alt, class: 'hh-hero__bg-img' }}
    {%- else -%}
      <img src="https://images.unsplash.com/photo-1626015449731-d586b6e34d2c?w=2000&q=80" alt="" class="hh-hero__bg-img" loading="eager" width="2000" height="1200">
    {%- endif -%}
  </div>
  <div class="hh-page">
    <div class="hh-hero__card hh-reveal">
      <span class="hh-eyebrow">{{ section.settings.eyebrow }}</span>
      <h1 class="hh-display">{{ section.settings.heading }}</h1>
      <p class="hh-hero__lead">{{ section.settings.lead }}</p>
      {%- if section.settings.cta_text != blank -%}
        <a class="hh-btn hh-btn--solid" href="{{ section.settings.cta_link }}">{{ section.settings.cta_text }}</a>
      {%- endif -%}
    </div>
  </div>
</section>
{% stylesheet %}
.hh-hero { position: relative; min-height: 88vh; }
.hh-hero__bg { position: absolute; inset: 0; overflow: hidden; }
.hh-hero__bg-img { width: 100%; height: 100%; object-fit: cover; }
.hh-hero .hh-page { position: relative; min-height: 88vh; display: grid; align-items: center; padding-top: 4rem; }
.hh-hero__card { background: var(--hh-paper); padding: clamp(1.75rem, 3vw, 2.5rem); border-radius: var(--hh-radius-lg); max-width: 460px; box-shadow: 0 24px 60px rgba(28, 36, 24, 0.15); display: grid; gap: var(--hh-space-3); margin-left: clamp(2rem, 8vw, 6rem); margin-top: 4vh; }
.hh-hero__card .hh-display { font-size: clamp(2rem, 3vw + 0.5rem, 3rem); }
.hh-hero__lead { font-size: 0.95rem; color: var(--hh-ink-soft); }
.hh-hero__card .hh-btn { justify-self: start; margin-top: var(--hh-space-3); }
@media (max-width: 880px) { .hh-hero__card { margin: 40vh auto 2rem; max-width: none; } }
{% endstylesheet %}
{% schema %}
{ "name": "Hero", "tag": "section", "settings": [
  { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Hair care, considered." },
  { "type": "text", "id": "heading", "label": "Heading", "default": "Slow rituals for everyday hair." },
  { "type": "textarea", "id": "lead", "label": "Lead", "default": "Botanically-led haircare made in small batches. Cold-pressed oils, plant proteins, and pH-balanced cleansers — formulated for scalp and shine, not just shelf appeal." },
  { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Shop the range" },
  { "type": "url", "id": "cta_link", "label": "CTA link" },
  { "type": "image_picker", "id": "image", "label": "Background image" }
], "presets": [{ "name": "Hero" }] }
{% endschema %}
