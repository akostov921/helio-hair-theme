<section class="hh-test hh-section">
  <div class="hh-page">
    <header class="hh-test__head">
      {%- if section.settings.eyebrow != blank -%}<span class="hh-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2 class="hh-h2">{{ section.settings.heading }}</h2>
    </header>
    <div class="hh-test__grid">
      {%- for block in section.blocks -%}
        <figure class="hh-test__card" {{ block.shopify_attributes }}>
          {%- if block.settings.stars -%}<div class="hh-test__stars">★★★★★</div>{%- endif -%}
          <blockquote>"{{ block.settings.quote }}"</blockquote>
          <figcaption>— {{ block.settings.author }}{% if block.settings.byline %}, <em>{{ block.settings.byline }}</em>{% endif %}</figcaption>
        </figure>
      {%- endfor -%}
    </div>
  </div>
</section>
{% stylesheet %}
.hh-test__head { display: grid; gap: 0.5rem; margin-bottom: 3rem; max-width: 56ch; }
.hh-test__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
.hh-test__card { background: rgba(0,0,0,0.04); padding: 2rem; border-radius: 8px; display: grid; gap: 1rem; margin: 0; }
.hh-test__stars { font-size: 0.9rem; letter-spacing: 0.15em; }
.hh-test__card blockquote { font-size: 1.0625rem; line-height: 1.55; margin: 0; }
.hh-test__card figcaption { font-size: 0.875rem; opacity: 0.7; }
{% endstylesheet %}
{% schema %}
{ "name": "Testimonials", "tag": "section", "settings": [
  { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Customer letters" },
  { "type": "text", "id": "heading", "label": "Heading", "default": "What people are saying." }
], "blocks": [
  { "type": "quote", "name": "Testimonial", "settings": [
    { "type": "checkbox", "id": "stars", "label": "Show stars", "default": true },
    { "type": "textarea", "id": "quote", "label": "Quote", "default": "It just works the way I'd hoped. I keep coming back." },
    { "type": "text", "id": "author", "label": "Author", "default": "M. P." },
    { "type": "text", "id": "byline", "label": "Byline" }
  ]}
], "max_blocks": 6, "presets": [{ "name": "Testimonials", "blocks": [
  { "type": "quote", "settings": { "author": "Sarah L." } },
  { "type": "quote", "settings": { "author": "James K." } },
  { "type": "quote", "settings": { "author": "Priya M." } }
]}]}
{% endschema %}
