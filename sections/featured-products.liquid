{%- comment %} collection.asymmetric-tiles.5-shape — repeating ABCDE rhythm {% endcomment -%}
<section class="hh-feat hh-section" data-section-id="{{ section.id }}">
  <div class="hh-page">
    <header class="hh-feat__head hh-reveal">
      <div>
        <span class="hh-eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 class="hh-h2 hh-italic">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.link_url != blank -%}<a class="hh-link" href="{{ section.settings.link_url }}">{{ section.settings.link_text }}</a>{%- endif -%}
    </header>
    {%- assign coll = section.settings.collection -%}
    {%- assign show_limit = section.settings.products_to_show | default: 10 -%}
    <div class="hh-feat__asym">
      {%- if coll.products.size > 0 -%}
        {%- for product in coll.products limit: show_limit -%}
          {%- assign slot_index = forloop.index0 | modulo: 5 -%}
          {%- case slot_index -%}{%- when 0 -%}{%- assign slot = 'a' -%}{%- when 1 -%}{%- assign slot = 'b' -%}{%- when 2 -%}{%- assign slot = 'c' -%}{%- when 3 -%}{%- assign slot = 'd' -%}{%- else -%}{%- assign slot = 'e' -%}{%- endcase -%}
          <a class="hh-asym__tile hh-asym__tile--{{ slot }} hh-reveal" href="{{ product.url }}">
            {%- if product.featured_image -%}{%- assign atile = product.title | escape -%}{{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: atile }}
            {%- else -%}<div class="hh-asym__ph" style="background:linear-gradient(135deg,var(--hh-sage) 0%,var(--hh-clay) 100%);"></div>{%- endif -%}
            <span class="hh-asym__label">{{ product.title }} · {{ product.price | money_without_trailing_zeros }}</span>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..5) -%}
          {%- assign slot_index = forloop.index0 | modulo: 5 -%}
          {%- case slot_index -%}{%- when 0 -%}{%- assign slot = 'a' -%}{%- when 1 -%}{%- assign slot = 'b' -%}{%- when 2 -%}{%- assign slot = 'c' -%}{%- when 3 -%}{%- assign slot = 'd' -%}{%- else -%}{%- assign slot = 'e' -%}{%- endcase -%}
          <div class="hh-asym__tile hh-asym__tile--{{ slot }} hh-reveal">
            <img src="https://images.unsplash.com/photo-{{ '1631730486572-226d1f595b68,1626015449731-d586b6e34d2c,1601049541289-9b1b7bbbfe19,1571423023395-c8f9e1a3ad33,1556228720-195a672e8a03' | split: ',' | slice: forloop.index0 | first }}?w=800&q=80" alt="" loading="lazy" width="800" height="800">
            <span class="hh-asym__label">Botanical wash · $28</span>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
.hh-feat__head { display: flex; justify-content: space-between; align-items: end; gap: var(--hh-space-4); margin-bottom: var(--hh-space-6); }
.hh-feat__head h2 { margin-top: var(--hh-space-2); }
.hh-feat__asym { display: grid; grid-template-columns: repeat(6, 1fr); grid-auto-rows: 220px; gap: var(--hh-space-3); }
.hh-asym__tile { position: relative; overflow: hidden; border-radius: var(--hh-radius); display: block; background: var(--hh-bg-2); }
.hh-asym__tile img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--hh-dur-slow) var(--hh-ease); }
.hh-asym__tile:hover img { transform: scale(1.03); }
.hh-asym__ph { width: 100%; height: 100%; }
.hh-asym__tile--a { grid-column: span 2; }
.hh-asym__tile--b { grid-column: span 2; grid-row: span 2; }
.hh-asym__tile--c { grid-column: span 2; }
.hh-asym__tile--d { grid-column: span 3; }
.hh-asym__tile--e { grid-column: span 1; grid-row: span 2; }
.hh-asym__label { position: absolute; left: var(--hh-space-3); bottom: var(--hh-space-3); background: rgba(251, 246, 236, 0.94); padding: 0.3rem 0.7rem; border-radius: var(--hh-radius); font-size: var(--hh-fs-xs); color: var(--hh-ink); backdrop-filter: blur(8px); font-weight: 500; }
@media (max-width: 880px) { .hh-feat__asym { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 200px; }
  .hh-asym__tile--a, .hh-asym__tile--b, .hh-asym__tile--c, .hh-asym__tile--d, .hh-asym__tile--e { grid-column: auto; grid-row: auto; }
}
{% endstylesheet %}
{% schema %}
{ "name": "Featured (asymmetric)", "tag": "section", "settings": [
  { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The range" },
  { "type": "text", "id": "heading", "label": "Heading", "default": "Everyday rituals." },
  { "type": "collection", "id": "collection", "label": "Collection" },
  { "type": "range", "id": "products_to_show", "label": "Products", "min": 5, "max": 15, "step": 1, "default": 10 },
  { "type": "text", "id": "link_text", "label": "Link text", "default": "Explore the range" },
  { "type": "url", "id": "link_url", "label": "Link" }
], "presets": [{ "name": "Featured (asymmetric)" }] }
{% endschema %}
