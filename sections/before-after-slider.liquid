<section class="hh-ba hh-section">
  <div class="hh-page hh-ba__grid">
    <div class="hh-ba__copy">
      <span class="hh-eyebrow">{{ section.settings.eyebrow | default: 'RESULTS' }}</span>
      <h2 class="hh-h2">{{ section.settings.heading }}</h2>
      <p class="hh-lead">{{ section.settings.body }}</p>
      {%- if section.settings.stat_number != blank -%}<div class="hh-ba__stat"><strong>{{ section.settings.stat_number }}</strong><span>{{ section.settings.stat_label }}</span></div>{%- endif -%}
    </div>
    <div class="hh-ba__visual" id="hh-ba-{{ section.id }}">
      <img class="hh-ba__before" src="{{ section.settings.before_url | default: 'https://images.unsplash.com/photo-1559599101-f09722fb4948?w=800&q=80' }}" alt="Before" width="800" height="800" loading="lazy">
      <div class="hh-ba__after-wrap" style="--reveal: 50%">
        <img class="hh-ba__after" src="{{ section.settings.after_url | default: 'https://images.unsplash.com/photo-1556228720-195a672e8a03?w=800&q=80' }}" alt="After" width="800" height="800" loading="lazy">
      </div>
      <div class="hh-ba__handle" aria-hidden="true">⇆</div>
      <input class="hh-ba__range" type="range" min="0" max="100" value="50" aria-label="Reveal slider">
    </div>
  </div>
</section>
<script>(() => { const root = document.getElementById('hh-ba-{{ section.id }}'); if (!root) return; const r = root.querySelector('.hh-ba__range'); const w = root.querySelector('.hh-ba__after-wrap'); const h = root.querySelector('.hh-ba__handle'); r.addEventListener('input', () => { const v = r.value + '%'; w.style.setProperty('--reveal', v); h.style.left = v; }); })();</script>
{% stylesheet %}
.hh-ba__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
.hh-ba__copy { display: grid; gap: 1rem; max-width: 50ch; }
.hh-ba__stat { display: grid; gap: 0.25rem; padding-top: 1rem; border-top: 1px solid rgba(0,0,0,0.1); }
.hh-ba__stat strong { font-family: var(--hh-serif); font-size: 2rem; line-height: 1; }
.hh-ba__visual { position: relative; aspect-ratio: 1; border-radius: 8px; overflow: hidden; }
.hh-ba__before, .hh-ba__after { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
.hh-ba__after-wrap { position: absolute; inset: 0; clip-path: inset(0 calc(100% - var(--reveal, 50%)) 0 0); overflow: hidden; }
.hh-ba__handle { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; padding: 0.5rem 0.75rem; border-radius: 999px; pointer-events: none; box-shadow: 0 4px 16px rgba(0,0,0,0.2); }
.hh-ba__range { position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0; cursor: ew-resize; }
@media (max-width: 880px) { .hh-ba__grid { grid-template-columns: 1fr; } }
{% endstylesheet %}
{% schema %}
{ "name": "Before / after", "tag": "section", "settings": [
  { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "RESULTS" },
  { "type": "text", "id": "heading", "label": "Heading", "default": "Visible difference in 14 days." },
  { "type": "textarea", "id": "body", "label": "Body", "default": "Independent split-test, 32 participants. Drag the slider to compare." },
  { "type": "text", "id": "stat_number", "label": "Stat number", "default": "+47%" },
  { "type": "text", "id": "stat_label", "label": "Stat label", "default": "Shine measured at week 4" },
  { "type": "text", "id": "before_url", "label": "Before image URL" },
  { "type": "text", "id": "after_url", "label": "After image URL" }
], "presets": [{ "name": "Before / after" }]}
{% endschema %}
