{%- form 'storefront_password' -%}
  {{ form.errors | default_errors }}
  <div style="display: flex; gap: 0.5rem; justify-content: center; margin-top: 1rem;">
    <input type="password" name="password" class="hh-input" placeholder="Password" required style="max-width: 240px;">
    <button type="submit" class="hh-btn">Enter</button>
  </div>
{%- endform -%}
