<section class="hh-section"><div class="hh-page hh-page--narrow">
  <h1 class="hh-display">Reset password</h1>
  {%- form 'reset_customer_password' -%}
    {{ form.errors | default_errors }}
    <label class="hh-eyebrow">New password <input class="hh-input" name="customer[password]" type="password" required></label>
    <label class="hh-eyebrow">Confirm <input class="hh-input" name="customer[password_confirmation]" type="password" required></label>
    <button type="submit" class="hh-btn">Reset</button>
  {%- endform -%}
</div></section>
