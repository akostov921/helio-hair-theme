<section class="hh-section"><div class="hh-page hh-page--narrow">
  <h1 class="hh-display">Activate account</h1>
  <p class="hh-lead">Set a password to finish activating your account.</p>
  {%- form 'activate_customer_password' -%}
    {{ form.errors | default_errors }}
    <label class="hh-eyebrow">Password <input class="hh-input" name="customer[password]" type="password" required></label>
    <label class="hh-eyebrow">Confirm <input class="hh-input" name="customer[password_confirmation]" type="password" required></label>
    <button type="submit" class="hh-btn">Activate</button>
  {%- endform -%}
</div></section>
