<section class="hh-section"><div class="hh-page hh-page--narrow">
  <header><span class="hh-eyebrow">Account</span><h1 class="hh-display">Sign in</h1></header>
  <div class="hh-rule"></div>
  {%- form 'customer_login', class: 'hh-auth' -%}
    {{ form.errors | default_errors }}
    <label class="hh-eyebrow">Email <input class="hh-input" name="customer[email]" type="email" required></label>
    <label class="hh-eyebrow">Password <input class="hh-input" name="customer[password]" type="password" required></label>
    <button type="submit" class="hh-btn">Sign in</button>
    <p class="hh-auth__alt"><a class="hh-link" href="{{ routes.account_recover_url }}">Forgot password</a> · <a class="hh-link" href="{{ routes.account_register_url }}">Create account</a></p>
  {%- endform -%}
</div></section>
<style>.hh-auth { display: grid; gap: var(--hh-space-4); margin-top: var(--hh-space-4); } .hh-auth label { display: grid; gap: var(--hh-space-1); } .hh-auth__alt { font-size: var(--hh-fs-sm); display: flex; gap: var(--hh-space-2); }</style>
