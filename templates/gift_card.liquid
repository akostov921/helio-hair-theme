<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Gift card — {{ shop.name }}</title>
{{ 'base.css' | asset_url | stylesheet_tag }}</head>
<body><main class="hh-page hh-page--narrow hh-section">
  <header style="text-align: center;"><span class="hh-eyebrow">{{ shop.name }}</span><h1 class="hh-display">Gift card</h1></header>
  <div style="border: 1px solid var(--hh-ink); padding: var(--hh-space-7); margin-top: var(--hh-space-6); text-align: center;">
    <span class="hh-eyebrow">Value</span>
    <p class="hh-display" style="font-size: 4rem; color: var(--hh-accent);">{{ gift_card.balance | money_without_trailing_zeros }}</p>
    <p style="margin-top: 1rem;"><strong>Code</strong><br><code style="background: var(--hh-paper-2); padding: 0.5rem 1rem; letter-spacing: 0.08em; font-family: monospace;">{{ gift_card.code | format_code }}</code></p>
    {%- if gift_card.expires_on -%}<small>Expires {{ gift_card.expires_on | date: '%B %-d, %Y' }}</small>{%- endif -%}
    <p style="margin-top: 1.5rem;"><a class="hh-btn" href="{{ shop.url }}">Choose a book</a></p>
  </div>
</main></body></html>
